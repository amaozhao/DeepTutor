{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist/node-tests",
    "rootDir": ".",
    "baseUrl": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "incremental": false,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["tests/**/*.ts"]
}
